# 生产环境配置
# Production Environment Configuration

# API 基础 URL (Docker 环境中使用 API Gateway)
VITE_API_BASE_URL=http://localhost:8080

# 应用标题
VITE_APP_TITLE=心理健康平台

# 应用版本
VITE_APP_VERSION=1.0.0

# 环境标识
VITE_ENV=production

# WebSocket URL
VITE_WS_URL=ws://localhost:8080/ws

# Gemini API Key (生产环境通过构建参数传入)
# VITE_GEMINI_API_KEY will be set via Docker build args

# 是否启用调试模式
VITE_DEBUG=false

# 日志级别
VITE_LOG_LEVEL=error

# 是否启用 Mock 数据
VITE_ENABLE_MOCK=false
