# 生产环境配置
# Production Environment Configuration

# API 基础 URL (生产环境需要配置实际的 API 地址)
VITE_API_BASE_URL=https://api.mentalhealth.com

# 应用标题
VITE_APP_TITLE=心理健康平台

# 应用版本
VITE_APP_VERSION=1.0.0

# 环境标识
VITE_ENV=production

# WebSocket URL
VITE_WS_URL=wss://api.mentalhealth.com/ws

# Gemini API Key (生产环境需要配置实际的密钥)
VITE_GEMINI_API_KEY=your-production-gemini-api-key

# 是否启用调试模式
VITE_DEBUG=false

# 日志级别 (debug, info, warn, error)
VITE_LOG_LEVEL=error

# 是否启用 Mock 数据
VITE_ENABLE_MOCK=false
